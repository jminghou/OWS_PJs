# ============================================================
# Claire Outline 知識庫 - 環境變數
# 複製此檔為 .env 並填入實際值
# ============================================================

# ── Outline 核心設定 ──────────────────────────────────────────
SECRET_KEY=<用 openssl rand -hex 32 產生>
UTILS_SECRET=<用 openssl rand -hex 32 產生>

# ── 資料庫 ────────────────────────────────────────────────────
POSTGRES_PASSWORD=<設定一個強密碼>
DATABASE_URL=postgres://outline_claire:${POSTGRES_PASSWORD}@postgres:5432/outline_claire
DATABASE_CONNECTION_POOL_MIN=2
DATABASE_CONNECTION_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── 對外網址 ──────────────────────────────────────────────────
URL=https://km.clairelab.tw
PORT=3000
FORCE_HTTPS=true

# ── MinIO / S3 檔案儲存 ──────────────────────────────────────
AWS_ACCESS_KEY_ID=outline_claire
AWS_SECRET_ACCESS_KEY=<設定一個強密碼>
AWS_REGION=us-east-1
AWS_S3_UPLOAD_BUCKET_NAME=outline-claire
AWS_S3_UPLOAD_BUCKET_URL=http://minio:9000
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_ACL=private
FILE_STORAGE=s3

# MinIO 管理帳號（與 S3 Access Key 相同）
MINIO_ROOT_USER=outline_claire
MINIO_ROOT_PASSWORD=<與 AWS_SECRET_ACCESS_KEY 相同>

# ── 認證方式（使用 Email 登入）─────────────────────────────
# 如需 Google/Slack OAuth，請參考 Outline 官方文件設定
# 預設使用 Email 驗證碼登入
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@clairelab.tw
SMTP_SECURE=true

# ── 其他 ──────────────────────────────────────────────────────
DEFAULT_LANGUAGE=zh_TW
PGSSLMODE=disable
NODE_ENV=production
LOG_LEVEL=info
